    "@squash/contracts": "*",
    "@squash/design-tokens": "*",
    "@squash/i18n": "*",
    "@tanstack/query-async-storage-persister": "^5.81.5",
    "@tanstack/react-query": "^5.81.5",
    "@tanstack/react-query-persist-client": "^5.81.5",
    "axios": "^1.11.0",
    "better-auth": "^1.6.0",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-image-picker": "~56.0.0",
    "expo-linking": "~56.0.14",
    "expo-network": "~56.0.0",
    "expo-notifications": "~56.0.0",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.0",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^0.540.0",
